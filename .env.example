# Lepton Press — dedicated Arc Testnet BURNER keys only. Never a real-money key.
# Get test USDC (the native gas token) at https://faucet.circle.com

# Publisher wallet: receives + withdraws the reader's stream.
SERVER_PRIVATE_KEY=0x...

# Reader agent wallet: opens the StreamPay stream and pays per paragraph.
AGENT_PRIVATE_KEY=0x...

# ── broker.js (two-hop value chain) only ──────────────────────────────────────
# Broker agent wallet: reads from the publisher AND receives from the consumer.
# (Can reuse AGENT_PRIVATE_KEY — same role as the reader on hop 1.)
BROKER_PRIVATE_KEY=0x...
# Downstream consumer wallet: pays the broker for the synthesized answer.
CONSUMER_PRIVATE_KEY=0x...

# ── LLM judge + synthesis (optional) ──────────────────────────────────────────
# When set, reader.js / broker.js score paragraphs and synthesize with Claude.
# Unset → both fall back to an inspectable heuristic, so the demo is self-contained.
# ANTHROPIC_API_KEY=sk-ant-...
# JUDGE_MODEL=claude-opus-4-8

# Optional overrides (sane Arc-testnet defaults are built in):
# RPC_URL=https://rpc.testnet.arc.network
# STREAM_PAY=0x505739d33D85AD85D0f9eeE64856309782382450
# SERVER_URL=http://localhost:4030
# ARTICLE=arc-nanopayments
# BUDGET_USDC=0.02
# READ_BUDGET_USDC=0.02   # broker upstream budget
# MARKUP=0.6              # broker resale markup (0.6 = +60%)
